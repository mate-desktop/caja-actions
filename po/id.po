msgid "<b>Assistants</b>"
msgstr "<b>Asisten</b>"

#: src/cact/cact-preferences.ui:707
msgid "Automatically _saves pending modifications"
msgstr "Simpan otomatis modifikasi yang masih tertunda"

#: src/cact/cact-preferences.ui:711
msgid ""
"When this option is checked, pending modification will be periodically and "
"automatically saved."
msgstr ""
"Ketika opsi ini dicentang, modifikasi yang masih tertunda akan disimpan "
"secara berkala dan otomatis."

