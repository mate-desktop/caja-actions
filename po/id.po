msgid "Periodicity :"
msgstr "Periode :"

#: src/cact/cact-preferences.ui:764
msgid "minutes"
msgstr "menit"

#: src/cact/cact-preferences.ui:789
msgid "<b>Auto-save</b>"
msgstr "<b>Simpan otomatis</b>"

#: src/cact/cact-preferences.ui:809
msgid ""
"This tab allows the user to choose custom preferences for the Caja-Actions "
