msgid "Click to add a new default scheme."
msgstr "Klik untuk menambahkan skema default baru."

#: src/cact/cact-preferences.ui:1091
msgid "Click to remove the selected default scheme."
msgstr "Klik untuk menghapus skema default yang dipilih."

#: src/cact/cact-preferences.ui:1123
msgid "<b>Default schemes</b>"
msgstr "<b>Skema default</b>"

#: src/cact/cact-preferences.ui:1143
